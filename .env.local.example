# 使い方:
#   cp .env.local.example .env.local   # 実値を書き込む（.env.local は gitignore 済み）
#   source .env.local                  # ベンチ実行前にシェルへ読み込む
# 公開リポジトリのため、実トークンをこのファイルや他のファイルに書かないこと。

# Claude Code CLI のサブスク OAuth トークン（`claude setup-token` で発行）
export CLAUDE_CODE_OAUTH_TOKEN="sk-ant-oat01-xxxxxxxx"

# ★重要: これが残っていると claude -p が黙って従量課金APIになる。必ず外す
unset ANTHROPIC_API_KEY

# --- 任意の上書き（既定値は harness/config.py を参照） ---
# export LOCAL_BASE_URL="http://localhost:1234/v1"
# export LOCAL_MODEL="qwen3-coder-30b-a3b"
# export CLOUD_MODEL=""          # 空なら CLI 既定モデル
# export CLAUDE_BIN="claude"
